# Copy this file to scripts/pipeline.env and customize values.
# scripts that source pipeline.env:
# - run.sh
# - push_to_kaggle.sh
# - wait_for_kernel.sh
# - log_error.sh

# Kaggle account / kernel
KAGGLE_USER=your-kaggle-username
KERNEL_SLUG=isic2018-xai-evaluation
KERNEL_TITLE=ISIC2018 XAI Evaluation Pipeline
KERNEL_ID=your-kaggle-username/isic2018-xai-evaluation

# Notebook
NOTEBOOK=XAI_Evaluation_Pipeline_Kaggle.ipynb

# Kaggle dataset sources (comma-separated)
# REQUIRED: image dataset
# OPTIONAL: prepared CSV dataset from local preprocessing
# OPTIONAL: timm weights dataset
DATASET_SOURCES=sani84/isic-2018-classification

# Optional kernel settings
ENABLE_GPU=true
ENABLE_TPU=false
ENABLE_INTERNET=true
MACHINE_SHAPE=NvidiaTeslaT4

# Runtime behavior
POLL_INTERVAL=60
MAX_WAIT=36000
