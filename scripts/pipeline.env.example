# Copy this to scripts/pipeline.env and fill in your values.
# Never commit pipeline.env — it is gitignored.

# ── Kaggle identity ───────────────────────────────────────────────────────────
KAGGLE_USER=yehiasamir
KERNEL_SLUG=isic2018-xai-evaluation
KERNEL_TITLE=ISIC2018 XAI Evaluation Pipeline
KERNEL_ID=yehiasamir/isic2018-xai-evaluation

# ── Notebook ──────────────────────────────────────────────────────────────────
NOTEBOOK=XAI_Evaluation_Pipeline_Kaggle.ipynb

# ── Dataset sources (comma-separated Kaggle slugs) ────────────────────────────
# Your own uploaded ISIC 2018 data zip.
# If you named your dataset something else, update KAGGLE_DATASET_SLUG in A.1 too.
DATASET_SOURCES=yehiasamir/isic2018-dataset

# ── Kernel settings ───────────────────────────────────────────────────────────
ENABLE_GPU=true
ENABLE_TPU=false
ENABLE_INTERNET=true
MACHINE_SHAPE=NvidiaTeslaT4

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL=60
MAX_WAIT=36000
